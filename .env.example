# ------------------------------
# Core database (PostgreSQL)
# ------------------------------
POSTGRES_USER=admin
POSTGRES_PASSWORD=adminpassword
POSTGRES_DB=tcc_logs_db
POSTGRES_PORT=5432

# ------------------------------
# Data Lake (MinIO)
# ------------------------------
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=adminpassword
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET_BRONZE=logs-bronze
MINIO_BUCKET_SILVER=logs-silver

# ------------------------------
# Milvus (vetor)
# ------------------------------
MILVUS_PORT=19530
MILVUS_HEALTH_PORT=9091
MILVUS_COLLECTION=docs_logs_context
MILVUS_MINIO_ROOT_USER=minioadmin
MILVUS_MINIO_ROOT_PASSWORD=minioadmin
MILVUS_MINIO_CONSOLE_PORT=9002

# ------------------------------
# Ollama / LLM
# ------------------------------
OLLAMA_PORT=11434
OLLAMA_CHAT_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ------------------------------
# API / Frontend / Tracking
# ------------------------------
API_PORT=8000
GRADIO_PORT=7860
MLFLOW_PORT=5000
MLFLOW_EXPERIMENT_NAME=aiops-diagnosis
